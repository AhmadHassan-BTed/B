# Model Configuration
# Set to 'true' to use local inference (llama-cpp), 'false' for cloud (Groq)
USE_LOCAL_MODEL=false

# Groq API Key (Required if USE_LOCAL_MODEL=false)
# Get yours at: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Optional: Other configuration if needed in the future
# OPENAI_API_KEY=...
# ANTHROPIC_API_KEY=...
